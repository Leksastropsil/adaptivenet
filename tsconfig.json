{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "lib": [
            "ESNext"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "moduleResolution": "Bundler",
        "outDir": "dist",
        "types": [
            "@cloudflare/workers-types"
        ]
    },
    "include": [
        "src/**/*",
        "api/**/*"
    ]
}